<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════ PREMIUM LIGHT THEME (Matte-Dashboard SaaS style) ═══════════════ -->

    <!-- ── Semantic Colours ── -->
    <Color x:Key="PrimaryColor">#1D4ED8</Color>
    <Color x:Key="PrimaryHoverColor">#1E40AF</Color>
    <Color x:Key="PrimaryPressedColor">#172554</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningDeepColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerHoverColor">#DC2626</Color>
    <Color x:Key="IndigoColor">#7C3AED</Color>

    <!-- ── Surface Colours ── -->
    <Color x:Key="BackgroundColor">#EAECEF</Color>   <!-- Matte light-gray window shell -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>       <!-- Cards, panels — pure white -->
    <Color x:Key="CardColor">#FFFFFF</Color>

    <!-- ── Text Colours ── -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextSecondaryColor">#374151</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>

    <!-- ── Border Colours ── -->
    <Color x:Key="BorderColor">#E4E4E7</Color>        <!-- Ultra-soft default border -->
    <Color x:Key="BorderSoftColor">#F3F4F6</Color>    <!-- Nested background fill -->

    <!-- ── Navigation Colours ── -->
    <Color x:Key="NavBgColor">#FFFFFF</Color>
    <Color x:Key="NavTextColor">#374151</Color>
    <Color x:Key="NavActiveColor">#1D4ED8</Color>
    <Color x:Key="NavActiveBgColor">#EFF6FF</Color>
    <Color x:Key="NavHoverBgColor">#F3F4F6</Color>

    <!-- ── Status / Utility Colours ── -->
    <Color x:Key="StatusOffColor">#EF4444</Color>
    <Color x:Key="StatusOnColor">#10B981</Color>
    <Color x:Key="StatusOnGlowColor">#34D399</Color>
    <Color x:Key="TooltipBgColor">#1F2937</Color>
    <Color x:Key="TooltipTextColor">#F9FAFB</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="GlowColor">#1D4ED8</Color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- BRUSHES                                                -->
    <!-- ══════════════════════════════════════════════════════ -->

    <!-- ── Brand ── -->
    <SolidColorBrush x:Key="PrimaryBrush"        Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningDeepBrush"    Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush"    Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="IndigoBrush"         Color="{StaticResource IndigoColor}"/>
    
    <!-- ── Semantic Tints ── -->
    <SolidColorBrush x:Key="PrimaryTintBrush"    Color="#F0F6FF"/>
    <SolidColorBrush x:Key="IndigoTintBrush"     Color="#F5EEFF"/>
    <SolidColorBrush x:Key="IndigoDeepTintBrush" Color="#F5EEFF"/>
    <SolidColorBrush x:Key="SuccessTintBrush"    Color="#F0FDF4"/>
    <SolidColorBrush x:Key="WarningTintBrush"    Color="#FFFBEB"/>
    <SolidColorBrush x:Key="WarningDeepTintBrush" Color="#FFFBEB"/>
    <SolidColorBrush x:Key="DangerTintBrush"     Color="#FEF2F2"/>

    <!-- ── Surfaces ── -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush"           Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="HeaderBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FooterBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBrush"        Color="{StaticResource NavBgColor}"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"      Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="HeaderLabelBrush"    Color="#4B5563"/>

    <!-- ── Borders ── -->
    <SolidColorBrush x:Key="BorderBrush"         Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSoftBrush"     Color="{StaticResource BorderSoftColor}"/>

    <!-- ── Help Icon ── -->
    <SolidColorBrush x:Key="HelpIconBgBrush"     Color="#E5E7EB"/>
    <SolidColorBrush x:Key="HelpIconTextBrush"   Color="#6B7280"/>

    <!-- ── Navigation ── -->
    <SolidColorBrush x:Key="NavBgBrush"          Color="{StaticResource NavBgColor}"/>
    <SolidColorBrush x:Key="NavTextBrush"        Color="{StaticResource NavTextColor}"/>
    <SolidColorBrush x:Key="NavActiveBrush"      Color="{StaticResource NavActiveColor}"/>
    <SolidColorBrush x:Key="NavActiveBgBrush"    Color="{StaticResource NavActiveBgColor}"/>
    <SolidColorBrush x:Key="NavHoverBgBrush"     Color="{StaticResource NavHoverBgColor}"/>

    <!-- ── Status ── -->
    <SolidColorBrush x:Key="StatusOffBrush"      Color="{StaticResource StatusOffColor}"/>
    <SolidColorBrush x:Key="StatusOnBrush"       Color="{StaticResource StatusOnColor}"/>
    <SolidColorBrush x:Key="BusyBadgeTextBrush"       Color="#1D4ED8"/>
    <SolidColorBrush x:Key="BusyBadgeBackgroundBrush" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="BusyBadgeBorderBrush"     Color="#401D4ED8"/>
    <SolidColorBrush x:Key="ActiveBadgeTextBrush"       Color="#166534"/>
    <SolidColorBrush x:Key="ActiveBadgeBackgroundBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="ActiveBadgeBorderBrush"     Color="#40166534"/>

    <!-- ── Tooltip ── -->
    <SolidColorBrush x:Key="TooltipBgBrush"      Color="{StaticResource TooltipBgColor}"/>
    <SolidColorBrush x:Key="TooltipTextBrush"    Color="{StaticResource TooltipTextColor}"/>

    <!-- ── Misc ── -->
    <SolidColorBrush x:Key="ShadowBrush"         Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="GlowBrush"           Color="{StaticResource GlowColor}"/>

    <!-- ── Secondary Button ── -->
    <SolidColorBrush x:Key="ButtonSecondaryBrush"             Color="#F4F4F5"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush"        Color="#E4E4E7"/>
    <SolidColorBrush x:Key="ButtonSecondaryPressedBrush"      Color="#D4D4D8"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush"         Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBorderBrush"  Color="{StaticResource PrimaryColor}"/>

    <!-- ── Danger Button ── -->
    <SolidColorBrush x:Key="ButtonDangerBackgroundBrush"        Color="#FEF2F2"/>
    <SolidColorBrush x:Key="ButtonDangerHoverBackgroundBrush"   Color="#FEE2E2"/>
    <SolidColorBrush x:Key="ButtonDangerPressedBackgroundBrush" Color="#FECACA"/>

    <!-- ── Install Card ── -->
    <SolidColorBrush x:Key="InstallCardBrush"       Color="#EFF6FF"/>
    <SolidColorBrush x:Key="InstallCardBorderBrush" Color="#BFDBFE"/>
    <SolidColorBrush x:Key="InstallCardHeaderBrush" Color="#111827"/>
    <SolidColorBrush x:Key="InstallCardTextBrush"   Color="#374151"/>

    <!-- ── Table Rows ── -->
    <SolidColorBrush x:Key="RowBackgroundBrush"             Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="RowHoverBrush"                  Color="{StaticResource NavHoverBgColor}"/>
    <SolidColorBrush x:Key="ProfileBestRowBackgroundBrush"  Color="#EBF5FF"/>
    <SolidColorBrush x:Key="ProfileBestRowBorderBrush"      Color="#993390EC"/>

    <!-- ── Version Badge ── -->
    <SolidColorBrush x:Key="VersionBadgeBackgroundBrush" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="VersionBadgeTextBrush"       Color="#1D4ED8"/>

    <!-- ── Logo ── -->
    <SolidColorBrush x:Key="LogoBrush" Color="#F59E0B"/>

    <!-- ── Inputs ── -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputTextBrush"       Color="#111827"/>
    <SolidColorBrush x:Key="InputBorderBrush"     Color="#D1D5DB"/>

    <!-- ── ComboBox ── -->
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundBrush"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxItemTextBrush"              Color="#111827"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush"             Color="#F3F4F6"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush"          Color="#EFF6FF"/>
    <SolidColorBrush x:Key="ComboBoxDropDownTextBrush"          Color="#111827"/>
    <SolidColorBrush x:Key="ComboBoxDropDownSelectedTextBrush"  Color="#1D4ED8"/>

    <!-- ── Info / Callout ── -->
    <SolidColorBrush x:Key="InfoBrush"       Color="#0369A1"/>
    <SolidColorBrush x:Key="InfoBgBrush"     Color="#F0F9FF"/>
    <SolidColorBrush x:Key="InfoBorderBrush" Color="#BAE6FD"/>

    <!-- ── Overlay ── -->
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#66000000"/>

    <!-- ── Footer ── -->
    <SolidColorBrush x:Key="FooterHighlightBrush" Color="#1D4ED8" Opacity="0.08"/>

    <!-- ── Toggle Switch ── -->
    <SolidColorBrush x:Key="SwitchTrackOnBrush"   Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SwitchTrackOffBrush"  Color="#D1D5DB"/>
    <SolidColorBrush x:Key="SwitchThumbBrush"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SwitchDisabledBrush"  Color="{StaticResource TextMutedColor}"/>

    <!-- ── Focus Ring ── -->
    <SolidColorBrush x:Key="FocusRingBrush"       Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="FocusRingSubtleBrush" Color="#331D4ED8"/>

    <!-- ── Scrollbar ── -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush"        Color="#F4F4F5"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush"        Color="#D4D4D8"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush"   Color="#A1A1AA"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#71717A"/>

    <!-- ── Work Mode Cards ── -->
    <!-- Default: very soft zinc border, no visual weight -->
    <SolidColorBrush x:Key="WorkModeCardBorderBrush"         Color="#E4E4E7"/>
    <!-- Hover: gentle sky-blue tint — elegant, not aggressive -->
    <SolidColorBrush x:Key="WorkModeCardHoverBrush"          Color="#F8FAFC"/>
    <SolidColorBrush x:Key="WorkModeCardHoverBorderBrush"    Color="#93C5FD"/>
    <!-- Selected: clean brand blue border + ultra-faint blue fill -->
    <SolidColorBrush x:Key="WorkModeCardSelectedBorderBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="WorkModeCardSelectedBgBrush"     Color="#3B82F6"/>

    <!-- ── Hero Version Badge ── -->
    <SolidColorBrush x:Key="HeroVersionBadgeOnBackgroundBrush" Color="#EAFBF0"/>
    <SolidColorBrush x:Key="HeroVersionBadgeOnBorderBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="HeroVersionBadgeOnTextBrush" Color="#15803D"/>

    <SolidColorBrush x:Key="HeroVersionBadgeWarningBackgroundBrush" Color="#FFF7E6"/>
    <SolidColorBrush x:Key="HeroVersionBadgeWarningBorderBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="HeroVersionBadgeWarningTextBrush" Color="#B45309"/>

    <SolidColorBrush x:Key="HeroVersionBadgeActiveBackgroundBrush" Color="#EAF3FF"/>
    <SolidColorBrush x:Key="HeroVersionBadgeActiveBorderBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="HeroVersionBadgeActiveTextBrush" Color="#1D4ED8"/>

    <SolidColorBrush x:Key="HeroVersionBadgeOffBackgroundBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="HeroVersionBadgeOffBorderBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="HeroVersionBadgeOffTextBrush" Color="#475569"/>

    <!-- ── Update Badge Brushes ── -->
    <SolidColorBrush x:Key="UpdateBadgeNeutralBackgroundBrush" Color="#EAECEF"/>
    <SolidColorBrush x:Key="UpdateBadgeNeutralTextBrush" Color="#475569"/>
    <SolidColorBrush x:Key="UpdateBadgeAvailableBackgroundBrush" Color="#DFF8E6"/>
    <SolidColorBrush x:Key="UpdateBadgeAvailableTextBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="UpdateBadgeBusyBackgroundBrush" Color="#EAF3FF"/>
    <SolidColorBrush x:Key="UpdateBadgeBusyTextBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="UpdateBadgeErrorBackgroundBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="UpdateBadgeErrorTextBrush" Color="#B91C1C"/>

    <!-- ── Scenario Context Badge Brushes ── -->
    <SolidColorBrush x:Key="ScenarioContextBadgeBackgroundBrush" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="ScenarioContextBadgeTextBrush" Color="#0369A1"/>
    <SolidColorBrush x:Key="ScenarioContextBadgeSecondaryBackgroundBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ScenarioContextBadgeSecondaryTextBrush" Color="#475569"/>

</ResourceDictionary>
