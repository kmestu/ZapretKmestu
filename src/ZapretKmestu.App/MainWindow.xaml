<Window x:Class="ZapretKmestu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapret Kmestu"
        Width="980" Height="720"
        MinWidth="860" MinHeight="620"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        Icon="Assets/Icons/app.ico"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
        <Style x:Key="ModeOptionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Cp"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"  Property="Background"   Value="{DynamicResource ButtonSecondaryHoverBrush}"/>
                                <Setter TargetName="Bd"  Property="BorderBrush"  Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground"   Value="{DynamicResource ButtonSecondaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource ButtonSecondaryPressedBrush}"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for inactive tab button -->
        <Style x:Key="TabDiagButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonSecondaryHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for active tab button -->
        <Style x:Key="TabDiagButtonActiveStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.06" Color="{DynamicResource ShadowColor}"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderRoundIconButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background"       Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground"       Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Width"            Value="28"/>
            <Setter Property="Height"           Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════ HEADER ══════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Color="{DynamicResource ShadowColor}"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconLightning}" Fill="{DynamicResource LogoBrush}" Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="Zapret Kmestu" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource VersionBadgeBackgroundBrush}" CornerRadius="6" Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v0.2 beta" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource VersionBadgeTextBrush}"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- Icon button 1: Check updates -->
                    <Button x:Name="UpdateCheckButton"
                            Style="{StaticResource HeaderRoundIconButtonStyle}"
                            Click="UpdateCheckButton_Click"
                            Margin="0,0,6,0"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.BetweenShowDelay="0"
                            ToolTip="Проверить наличие новой версии zapret.">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Viewbox.RenderTransform>
                                <RotateTransform x:Name="UpdateCheckIconRotation" Angle="0"/>
                            </Viewbox.RenderTransform>
                            <Path x:Name="UpdateRefreshIconPath" Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>

                    <!-- Icon button 2: Install/update -->
                    <Button x:Name="HeaderInstallUpdateButton"
                            Style="{StaticResource HeaderRoundIconButtonStyle}"
                            Click="HeaderInstallUpdateButton_Click"
                            Margin="0,0,10,0"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.BetweenShowDelay="0">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path x:Name="HeaderInstallUpdateIconPath" Data="{StaticResource IconBoxDownload}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>

                    <Border x:Name="UpdateStatusBorder" CornerRadius="8" Padding="10,0" Height="26"
                            VerticalAlignment="Center" Background="{DynamicResource UpdateBadgeNeutralBackgroundBrush}" BorderThickness="0" 
                            MinWidth="140" HorizontalAlignment="Center" Cursor="Hand" PreviewMouseLeftButtonDown="UpdateStatusBorder_PreviewMouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateStatusText" Margin="0" TextAlignment="Center"
                                       Text="Не проверено" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource UpdateBadgeNeutralTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Path x:Name="UpdateStatusArrow" Width="8" Height="5" Margin="4,0,0,0"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{DynamicResource UpdateBadgeNeutralTextBrush}"
                                  VerticalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Popup x:Name="UpdateCenterPopup" PlacementTarget="{Binding ElementName=UpdateStatusBorder}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,4,0,8" Padding="0,4" Width="{Binding ActualWidth, ElementName=UpdateStatusBorder}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25" Color="{DynamicResource ShadowColor}"/>
                            </Border.Effect>
                            <StackPanel>
                                <ItemsControl x:Name="UpdateItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="UpdateItem_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0" Margin="4,2">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BgBorder" Background="Transparent" Padding="8,6" CornerRadius="6">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}" Grid.Column="0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding Description}"/>
                                                                <TextBlock Text="{Binding Version}" Grid.Column="1" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="8,0,0,0" ToolTip="{Binding Version}"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource ButtonSecondaryPressedBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════ BODY ══════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="196"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT NAV ─── -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="10,14,10,14">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="НАВИГАЦИЯ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="14,0,0,8"/>
                        <Button x:Name="NavHomeButton" Style="{DynamicResource NavButtonActiveStyle}" Click="NavHome_Click" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconHome}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Главная" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavExpertButton" Style="{DynamicResource NavButtonStyle}" Click="NavExpert_Click" Margin="0,0,0,2" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconProfiles}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Профили" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavScenariosButton" Style="{DynamicResource NavButtonStyle}" Click="NavScenarios_Click" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconShield}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Game Filter" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavDiagButton" Style="{DynamicResource NavButtonStyle}" Click="NavDiag_Click" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconGlobe}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Диагностика" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSettingsButton" Style="{DynamicResource NavButtonStyle}" Click="NavSettings_Click" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconSettings}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavLogButton" Style="{DynamicResource NavButtonStyle}" Click="NavLog_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconLog}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="Журнал" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="10,0,10,12" Opacity="0.5"/>
                        <Button x:Name="SidebarThemeToggleButton"
                                Style="{DynamicResource NavButtonStyle}"
                                Click="SidebarThemeToggleButton_Click"
                                ToolTip="Переключить цветовую тему приложения.">
                             <StackPanel Orientation="Horizontal">
                                 <Viewbox x:Name="SidebarThemeToggleIconContainer" Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                     <Path x:Name="SidebarThemeToggleIcon" Data="{StaticResource IconMoon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                 </Viewbox>
                                 <TextBlock x:Name="SidebarThemeToggleText" Text="Тёмная тема" VerticalAlignment="Center"/>
                             </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── CONTENT AREA ─── -->
            <Grid Grid.Column="1" Margin="20,18,20,18">

                <!-- ══════ PAGE: ГЛАВНАЯ ══════ -->
                <!-- ══════ PAGE: ГЛАВНАЯ ══════ -->
                <Grid x:Name="PageHome" Visibility="Visible">
                    <Grid.Resources>
                        <Style x:Key="CondensedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                            <Setter Property="Padding" Value="28,25"/>
                            <Setter Property="Margin" Value="0,0,0,14"/>
                        </Style>
                    </Grid.Resources>

                    <StackPanel>
                        <!-- Hero Status card -->
                        <Border Style="{StaticResource CondensedCardStyle}" Height="156" Padding="28,18">
                            <Border.Resources>
                                <Storyboard x:Key="StatusChangeAnimation">
                                    <DoubleAnimation Storyboard.TargetName="HeroIconCircle" Storyboard.TargetProperty="Opacity"
                                                     From="0.0" To="1.0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="HeroIconCircle" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     From="0.92" To="1.0" Duration="0:0:0.2">
                                         <DoubleAnimation.EasingFunction>
                                             <CubicEase EasingMode="EaseOut"/>
                                         </DoubleAnimation.EasingFunction>
                                     </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="HeroIconCircle" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     From="0.92" To="1.0" Duration="0:0:0.2">
                                         <DoubleAnimation.EasingFunction>
                                             <CubicEase EasingMode="EaseOut"/>
                                         </DoubleAnimation.EasingFunction>
                                     </DoubleAnimation>
                                </Storyboard>
                            </Border.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- Hero Status Icon -->
                                <Border x:Name="HeroIconCircle" Grid.Column="0"
                                        Width="80" Height="80" CornerRadius="40"
                                        Background="{DynamicResource RowBackgroundBrush}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="HeroIconCircleScale" ScaleX="1.0" ScaleY="1.0"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="HeroIconGlow" BlurRadius="24" ShadowDepth="1" Opacity="0" Color="Transparent"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.Clip>
                                            <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                        </Grid.Clip>


                                        <!-- HeroGlintHost: fixed layer with animated brush transform -->
                                        <Grid x:Name="HeroGlintHost" Width="80" Height="80" Opacity="0" IsHitTestVisible="False">
                                            <Rectangle x:Name="HeroGlintSoftLayer" Width="80" Height="80">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                                        <LinearGradientBrush.RelativeTransform>
                                                            <TranslateTransform x:Name="HeroGlintSoftBrushTransform" X="-0.85" Y="0.85" />
                                                        </LinearGradientBrush.RelativeTransform>
                                                        <GradientStop Offset="0.00" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="0.12" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="0.24" Color="#08FFFFFF"/>
                                                        <GradientStop Offset="0.34" Color="#16FFFFFF"/>
                                                        <GradientStop Offset="0.42" Color="#24FFFFFF"/>
                                                        <GradientStop Offset="0.47" Color="#32FFFFFF"/>
                                                        <GradientStop Offset="0.50" Color="#40FFFFFF"/>
                                                        <GradientStop Offset="0.53" Color="#32FFFFFF"/>
                                                        <GradientStop Offset="0.58" Color="#24FFFFFF"/>
                                                        <GradientStop Offset="0.66" Color="#16FFFFFF"/>
                                                        <GradientStop Offset="0.76" Color="#08FFFFFF"/>
                                                        <GradientStop Offset="0.88" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="1.00" Color="#00FFFFFF"/>
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Rectangle x:Name="HeroGlintCoreLayer" Width="80" Height="80">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                                        <LinearGradientBrush.RelativeTransform>
                                                            <TranslateTransform x:Name="HeroGlintCoreBrushTransform" X="-0.85" Y="0.85" />
                                                        </LinearGradientBrush.RelativeTransform>
                                                        <GradientStop Offset="0.00" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="0.20" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="0.32" Color="#08FFFFFF"/>
                                                        <GradientStop Offset="0.40" Color="#18FFFFFF"/>
                                                        <GradientStop Offset="0.45" Color="#34FFFFFF"/>
                                                        <GradientStop Offset="0.48" Color="#52FFFFFF"/>
                                                        <GradientStop Offset="0.50" Color="#66FFFFFF"/>
                                                        <GradientStop Offset="0.52" Color="#52FFFFFF"/>
                                                        <GradientStop Offset="0.55" Color="#34FFFFFF"/>
                                                        <GradientStop Offset="0.60" Color="#18FFFFFF"/>
                                                        <GradientStop Offset="0.68" Color="#08FFFFFF"/>
                                                        <GradientStop Offset="0.80" Color="#00FFFFFF"/>
                                                        <GradientStop Offset="1.00" Color="#00FFFFFF"/>
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Grid>
                                        <Viewbox x:Name="HeroIconViewbox" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
                                            <Path x:Name="HeroIconPath" Fill="White" Stretch="Uniform" />
                                        </Viewbox>
                                    </Grid>
                                </Border>
                                <Grid Grid.Column="1" Height="114" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <!-- Status Title -->
                                        <TextBlock x:Name="MainStatusText" Text="Обход выключен"
                                                   FontSize="30" FontWeight="Bold"
                                                   Foreground="{DynamicResource StatusOffBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   LineStackingStrategy="BlockLineHeight" LineHeight="36"
                                                   Margin="0"/>

                                        <!-- Helper Text -->
                                        <TextBlock x:Name="HeroHelperText" Text="Всё готово"
                                                   FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   LineStackingStrategy="BlockLineHeight" LineHeight="21"
                                                   Margin="0,6,0,10"/>

                                        <!-- Metadata Row -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                                            <Border x:Name="ProfileVersionBadge"
                                                    Height="26"
                                                    MinHeight="26"
                                                    CornerRadius="8"
                                                    Padding="10,0"
                                                    Background="{DynamicResource HeroVersionBadgeActiveBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HeroVersionBadgeActiveBorderBrush}"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed"
                                                    Margin="0"
                                                    MaxWidth="300"
                                                    HorizontalAlignment="Left"
                                                    ToolTipService.InitialShowDelay="0"
                                                    ToolTipService.BetweenShowDelay="0"
                                                    ToolTipService.ShowDuration="20000">
                                                <TextBlock x:Name="ProfileText" Text="zapret 1.9.8c"
                                                            FontSize="11" FontWeight="SemiBold"
                                                            Foreground="{DynamicResource HeroVersionBadgeActiveTextBrush}"
                                                            VerticalAlignment="Center"
                                                            LineStackingStrategy="BlockLineHeight" LineHeight="16"
                                                            TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                            Margin="0"/>
                                            </Border>
                                            <TextBlock x:Name="UptimeSeparator" Text=" · "
                                                        FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                        Visibility="Collapsed"
                                                        VerticalAlignment="Center"/>
                                            <TextBlock x:Name="UptimeText"
                                                        FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                        Visibility="Collapsed"
                                                        Text="работает сейчас"
                                                        VerticalAlignment="Center"
                                                        LineStackingStrategy="BlockLineHeight" LineHeight="16"
                                                        Margin="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Button Grid.Column="2" x:Name="ToggleButton"
                                        Style="{DynamicResource BigToggleButtonStyle}" Click="ToggleButton_Click"
                                        Width="280" Height="64" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="ToggleButtonText" Text="ВКЛЮЧИТЬ" FontSize="18" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Hidden Compatibility Elements (to avoid breaking code-behind) -->
                        <Grid Visibility="Collapsed">
                             <Button x:Name="InstallZapretButton" />
                             <TextBlock x:Name="InstallStatusHeader" />
                             <TextBlock x:Name="InstallStatusSubtext" />
                             <TextBlock x:Name="InstallBottomStatusText" />
                             <Border x:Name="InstallHelpBorder" />
                             <TextBlock x:Name="InstallHelpText" />
                             <Border x:Name="InstallCard" />
                        </Grid>

                        <!-- Management card -->
                        <Border Style="{StaticResource CondensedCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Profile zone Grid -->
                                <Grid Grid.Column="0" Height="102" Width="340" MaxWidth="350" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="22"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="40"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Header row -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                                        <Viewbox Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center" Opacity="0.6">
                                            <Path Data="{StaticResource IconProfiles}" Fill="{DynamicResource TextPrimaryBrush}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="ПРОФИЛЬ ОБХОДА" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeaderLabelBrush}" VerticalAlignment="Center"/>
                                        <Border Width="16" Height="16" Background="{DynamicResource BorderBrush}" CornerRadius="8"
                                                Margin="6,0,0,0" Cursor="Help" VerticalAlignment="Center"
                                                ToolTipService.InitialShowDelay="0"
                                                ToolTipService.BetweenShowDelay="0"
                                                ToolTipService.ShowDuration="20000">
                                            <Border.ToolTip>
                                                <ToolTip Style="{x:Null}" Background="Transparent" BorderThickness="0" Padding="0">
                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
                                                        <StackPanel>
                                                            <TextBlock Text="Выберите профиль zapret вручную или запустите автоподбор." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="250"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Grid spanning Row 2 to 4 (RowSpan=3) for toggled states -->
                                    <Grid Grid.Row="2" Grid.RowSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <!-- Normal state panel -->
                                        <Grid x:Name="LeftProfileNormalPanel" Visibility="Visible" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30"/>
                                                <RowDefinition Height="5"/>
                                                <RowDefinition Height="40"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 0: Selector Top Row -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Ручной выбор параметров" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                                <Button Grid.Column="1" x:Name="LastWizardResultsButton" Height="28" Width="156" MinWidth="156"
                                                        Visibility="Visible" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                        Click="LastWizardResultsButton_Click" Padding="10,0"
                                                        SnapsToDevicePixels="True" UseLayoutRounding="True">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                            <Setter Property="Background"       Value="{DynamicResource ButtonSecondaryBrush}"/>
                                                            <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="FontSize"         Value="12"/>
                                                            <Setter Property="FontWeight"       Value="Medium"/>
                                                            <Setter Property="BorderThickness"  Value="0"/>
                                                            <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="OuterStroke"
                                                                                Background="{TemplateBinding BorderBrush}"
                                                                                CornerRadius="14"
                                                                                Padding="2"
                                                                                SnapsToDevicePixels="True">
                                                                            <Border x:Name="InnerFill"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    CornerRadius="12"
                                                                                    Padding="{TemplateBinding Padding}"
                                                                                    SnapsToDevicePixels="True">
                                                                                <ContentPresenter x:Name="Cp"
                                                                                                  HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"
                                                                                                  RecognizesAccessKey="True"/>
                                                                            </Border>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="InnerFill" Property="Background" Value="{DynamicResource ButtonSecondaryHoverBrush}"/>
                                                                                <Setter TargetName="OuterStroke" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="InnerFill" Property="Background" Value="{DynamicResource ButtonSecondaryPressedBrush}"/>
                                                                                <Setter TargetName="OuterStroke" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter TargetName="OuterStroke" Property="Opacity" Value="0.55"/>
                                                                                <Setter TargetName="InnerFill" Property="Opacity" Value="0.55"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.8">
                                                            <Path Data="{StaticResource IconLog}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <TextBlock Text="Последний подбор" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Row 2: ComboBox -->
                                            <ComboBox Grid.Row="2" x:Name="HomeProfileComboBox" MaxDropDownHeight="274" Height="40" FontSize="13" Padding="12,0"
                                                      VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}"
                                                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                                      DisplayMemberPath="DisplayName" SelectionChanged="HomeProfileComboBox_SelectionChanged"
                                                      HorizontalAlignment="Stretch" Cursor="Hand">
                                                <ComboBox.Resources>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Padding" Value="12,0"/>
                                                        <Setter Property="Height" Value="34"/>
                                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                    </Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="6"/>
                                                    </Style>
                                                </ComboBox.Resources>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Busy state panel -->
                                        <Grid x:Name="LeftProfileBusyPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30"/>
                                                <RowDefinition Height="5"/>
                                                <RowDefinition Height="40"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Height="24" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.9">
                                                        <Path Data="{StaticResource IconProfileSearch}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                    </Viewbox>
                                                    <TextBlock Text="Идёт автоподбор" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                </StackPanel>
                                                
                                                <Border Grid.Column="1" 
                                                        Background="{DynamicResource BorderSoftBrush}" 
                                                        BorderBrush="{DynamicResource BorderBrush}" 
                                                        BorderThickness="1" 
                                                        CornerRadius="7" 
                                                        Padding="8,3" 
                                                        HorizontalAlignment="Right" 
                                                        VerticalAlignment="Center" 
                                                        Width="155">
                                                    <TextBlock x:Name="LeftProfileCheckingTimeText" 
                                                               Text="Оцениваем время…" 
                                                               FontSize="11" 
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="NoWrap"/>
                                                </Border>
                                            </Grid>
                                            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="8" 
                                                    Height="40" 
                                                    HorizontalAlignment="Stretch"
                                                    Padding="12,0">
                                                <TextBlock x:Name="LeftProfileCheckingNameText" 
                                                           Text="Подготовка профилей…" 
                                                           FontSize="13" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" 
                                                           VerticalAlignment="Center" 
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                            </Border>
                                        </Grid>

                                        <!-- Not Installed state panel -->
                                        <Grid x:Name="LeftProfileNotInstalledPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30"/>
                                                <RowDefinition Height="5"/>
                                                <RowDefinition Height="40"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Height="24" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Профили недоступны" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="8" 
                                                    Height="40" 
                                                    HorizontalAlignment="Stretch"
                                                    Padding="12,0"
                                                    Opacity="0.6">
                                                <TextBlock x:Name="LeftProfileNotInstalledText" 
                                                           Text="Сначала установите zapret" 
                                                           FontSize="12" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource TextMutedBrush}" 
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <!-- Right Column: Buttons -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="280" HorizontalAlignment="Right">
                                    <Grid Width="280" Height="42" HorizontalAlignment="Right" Margin="0,0,0,18">
                                        <Button x:Name="BestProfileButton" Height="42" Width="280" HorizontalAlignment="Right"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Click="BestProfileButton_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Viewbox Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8">
                                                    <Path Data="{StaticResource IconProfileSearch}" Fill="{DynamicResource TextPrimaryBrush}"/>
                                                </Viewbox>
                                                <TextBlock Text="Автоподбор" FontSize="12" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Operation Progress Field Overlay (Replacing Button) -->
                                        <Border x:Name="OperationProgressCard"
                                                Visibility="Collapsed"
                                                Panel.ZIndex="20"
                                                Width="280" Height="42"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Background="{DynamicResource ButtonSecondaryBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14,8,14,8">
                                            <Grid x:Name="InstallProgressPanel">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- Main Row: Icon, static text, percent -->
                                                <Grid Grid.Row="0" VerticalAlignment="Center" Margin="0,-2,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Viewbox Grid.Column="0" Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.8" Visibility="Collapsed">
                                                        <Path Data="{StaticResource IconProfileSearch}" Fill="{DynamicResource TextSecondaryBrush}"/>
                                                    </Viewbox>
                                                    
                                                    <TextBlock Grid.Column="1" Text="Подбор профиля" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                                
                                                    <TextBlock x:Name="InstallPercentText" Grid.Column="2" 
                                                               Text="0%" FontSize="11" FontWeight="Bold" 
                                                               Foreground="{DynamicResource PrimaryBrush}" 
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                                
                                                    <!-- Hidden required elements for code-behind compatibility -->
                                                    <TextBlock x:Name="InstallStepText" Visibility="Collapsed"/>
                                                    <Button x:Name="CancelOperationButton" Click="CancelOperationButton_Click" Visibility="Collapsed"/>
                                                </Grid>
                                                
                                                <!-- Bottom progress rail -->
                                                <ProgressBar Grid.Row="1" x:Name="InstallProgressBar" 
                                                             Height="4" Minimum="0" Maximum="100" Value="0"
                                                             Background="{DynamicResource BorderSoftBrush}" 
                                                             Foreground="{DynamicResource PrimaryBrush}"
                                                             BorderThickness="0" VerticalAlignment="Bottom" Margin="0,2,0,0">
                                                    <ProgressBar.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="2"/>
                                                         </Style>
                                                    </ProgressBar.Resources>
                                                </ProgressBar>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <Button x:Name="FixAllButton" Height="42" Width="280" HorizontalAlignment="Right"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Click="FixAllButton_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8">
                                                <Path Data="{StaticResource IconWrench}" Fill="{DynamicResource TextPrimaryBrush}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock Text="Починить всё" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ══════ PAGE: СЦЕНАРИИ ══════ -->
                <Grid x:Name="PageScenarios" Visibility="Collapsed" Margin="0,0,0,16" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.Resources>
                        <Style x:Key="GameFilterHelpIconStyle" TargetType="Border">
                            <Setter Property="Width" Value="14"/>
                            <Setter Property="Height" Value="14"/>
                            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="CornerRadius" Value="7"/>
                            <Setter Property="Margin" Value="6,0,0,0"/>
                            <Setter Property="Cursor" Value="Help"/>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
                            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
                            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                            <Setter Property="Opacity" Value="0.75"/>
                        </Style>

                        <Style TargetType="ToolTip">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToolTip">
                                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10" MaxWidth="380" MinWidth="280">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    
                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="20,20,20,16" Margin="0" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <!-- Header & Switch Area -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Left: Title & Toggle -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Game Filter" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="GameFilterToggle" Style="{StaticResource SettingsSwitchCheckBoxStyle}" VerticalAlignment="Center" Margin="12,0,0,0" Checked="GameFilterToggle_Changed" Unchecked="GameFilterToggle_Changed"/>
                                </StackPanel>
                                
                                <!-- Middle: Short hint when options are locked -->
                                <TextBlock Grid.Column="1" x:Name="GameFilterLockedHint" 
                                           Text="Изменения доступны после выключения" 
                                           FontSize="12" 
                                           Foreground="{DynamicResource TextMutedBrush}" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="16,0,16,0"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="Collapsed"/>
                                
                                <!-- Right: Status Badge -->
                                <Border Grid.Column="2" x:Name="ScenarioStatusBadge" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" HorizontalAlignment="Right" Background="{DynamicResource BorderSoftBrush}">
                                    <TextBlock x:Name="ApplyGameFilterStatusText" Text="Неактивен" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="ScenarioGameOptionsPanel" Visibility="Visible" Opacity="0.5" IsEnabled="False">
                                <!-- Type -->
                                <TextBlock Text="Тип трафика" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- UDP -->
                                    <Border Grid.Column="0" x:Name="GameFilterUdpButton" Height="42" CornerRadius="6" Cursor="Hand" Background="{DynamicResource PrimaryTintBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1.5" MouseLeftButtonDown="GameFilterButton_Click">
                                        <Grid>
                                            <TextBlock Text="UDP" Visibility="Collapsed"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="UDP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Style="{StaticResource GameFilterHelpIconStyle}">
                                                    <Border.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel>
                                                                <TextBlock Text="UDP" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                                <TextBlock Text="• Назначение: игровые сессии, голос, матчмейкинг." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                                <TextBlock Text="• Примеры: Discord voice, CS2, Dota 2." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- TCP -->
                                    <Border Grid.Column="2" x:Name="GameFilterTcpButton" Height="42" CornerRadius="6" Cursor="Hand" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" MouseLeftButtonDown="GameFilterButton_Click">
                                        <Grid>
                                            <TextBlock Text="TCP" Visibility="Collapsed"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="TCP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Style="{StaticResource GameFilterHelpIconStyle}">
                                                    <Border.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel>
                                                                <TextBlock Text="TCP" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                                <TextBlock Text="• Назначение: вход, лаунчеры, магазин/API." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                                <TextBlock Text="• Примеры: Steam login, Epic Games Launcher." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- TCP + UDP -->
                                    <Border Grid.Column="4" x:Name="GameFilterTcpUdpButton" Height="42" CornerRadius="6" Cursor="Hand" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" MouseLeftButtonDown="GameFilterButton_Click">
                                        <Grid>
                                            <TextBlock Text="TCP + UDP" Visibility="Collapsed"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="TCP + UDP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Style="{StaticResource GameFilterHelpIconStyle}">
                                                    <Border.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel>
                                                                <TextBlock Text="TCP + UDP" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                                <TextBlock Text="• Назначение: максимальная совместимость." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                                <TextBlock Text="• Для случаев, когда нужны игра, голос и лаунчер." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Scope -->
                                <TextBlock Text="Охват" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- По спискам -->
                                    <Border Grid.Column="0" x:Name="GameScopeListsButton" Height="42" CornerRadius="6" Cursor="Hand" Background="{DynamicResource SuccessTintBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1.5" MouseLeftButtonDown="GameScopeButton_Click">
                                        <Grid>
                                            <TextBlock Text="Только нужные адреса" Visibility="Collapsed"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="По спискам" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Style="{StaticResource GameFilterHelpIconStyle}">
                                                    <Border.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel>
                                                                <TextBlock Text="По спискам" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                                <TextBlock Text="• Назначение: безопасный старт." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                                <TextBlock Text="• Использует целевые списки сервисов." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Расширенный -->
                                    <Border Grid.Column="2" x:Name="GameScopeExtendedButton" Height="42" CornerRadius="6" Cursor="Hand" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" MouseLeftButtonDown="GameScopeButton_Click">
                                        <Grid>
                                            <TextBlock Text="Больше адресов" Visibility="Collapsed"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
