                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="Обновить список" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
