                                                            <TextBlock Text="Предупреждать, если одновременно используется VPN." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="360"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </CheckBox>

                                <CheckBox x:Name="MinimizeToTrayCheckbox" Style="{StaticResource SettingsSwitchCheckBoxStyle}"
                                          Margin="0,0,0,8"
                                          Checked="MinimizeToTrayCheckbox_Changed"
                                          Unchecked="MinimizeToTrayCheckbox_Changed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Сворачивать в трей" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="16" Height="16" Background="{DynamicResource BorderBrush}" CornerRadius="8"
                                                Margin="8,0,0,0" Cursor="Help" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="20000" VerticalAlignment="Center">
                                            <Border.ToolTip>
                                                <ToolTip Style="{x:Null}" Background="Transparent" BorderThickness="0" Padding="0">
                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
                                                        <StackPanel>
                                                            <TextBlock Text="Вместо закрытия сворачивать окно в область уведомлений." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="360"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </CheckBox>

                                <CheckBox x:Name="StopBypassOnAppExitCheckbox" Style="{StaticResource SettingsSwitchCheckBoxStyle}"
                                          Checked="StopBypassOnAppExitCheckbox_Changed"
                                          Unchecked="StopBypassOnAppExitCheckbox_Changed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Останавливать обход при выходе" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="16" Height="16" Background="{DynamicResource BorderBrush}" CornerRadius="8"
                                                Margin="8,0,0,0" Cursor="Help" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="20000" VerticalAlignment="Center">
                                            <Border.ToolTip>
                                                <ToolTip Style="{x:Null}" Background="Transparent" BorderThickness="0" Padding="0">
                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
                                                        <StackPanel>
                                                            <TextBlock Text="Автоматически отключать обход при полном выходе из программы." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="360"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- Row 2, Col 2: ОБСЛУЖИВАНИЕ -->
                        <Border Grid.Row="2" Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="16,8" Margin="0,0,0,18" VerticalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="ОБСЛУЖИВАНИЕ" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource HeaderLabelBrush}" Margin="0,0,0,6"/>

                                <!-- Folder Access -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="Файлы zapret" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="Папка профилей и списков" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{DynamicResource SecondaryButtonStyle}" Height="32" Width="120" Padding="12,0"
                                            Click="OpenZapretFolder_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Path Data="{StaticResource IconFolder}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock Text="Открыть" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,4" Opacity="0.5"/>

                                <!-- Deletion -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="Удалить zapret" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                        <TextBlock Text="Удаляет только движок" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button x:Name="UninstallAppButton" Grid.Column="1" Style="{DynamicResource DangerButtonStyle}" Height="32" Width="120" Padding="12,0"
                                            Click="UninstallZapretButton_Click">
                                        <TextBlock Text="Удалить zapret" VerticalAlignment="Center" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Grid x:Name="PageDiag" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <!-- Row 0: Tab Content Hosting -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: Refresh Button -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hidden tab buttons to preserve C# references safely -->
                    <StackPanel Visibility="Collapsed">
                        <Button x:Name="TabOverviewButton" Click="TabOverview_Click"/>
                        <Button x:Name="TabGraphsButton" Click="TabGraphs_Click"/>
                        <Button x:Name="TabLogButton" Click="TabLog_Click"/>
                    </StackPanel>

                    <!-- Row 0: Tab Content Hosting -->
                    <Grid Grid.Row="0">
                        <!-- ═════ TAB 1: ГРАФИКИ ═════ -->
                        <Grid x:Name="DiagGraphsTabContent" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- YouTube Chart Card -->
                            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="18,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header Row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Service Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Metrics Group Grid -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Width="28" Height="28" CornerRadius="6"
                                                Background="{DynamicResource BorderSoftBrush}"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource IconYoutube}" Fill="{DynamicResource DangerBrush}" Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>

                                        <!-- Service Name -->
                                        <TextBlock Grid.Column="1" Text="YouTube"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Rigid Metrics Group -->
                                        <Grid Grid.Column="2" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/> <!-- Status -->
                                                <ColumnDefinition Width="10"/> <!-- Spacing -->
                                                <ColumnDefinition Width="65"/> <!-- Latency -->
                                                <ColumnDefinition Width="10"/> <!-- Spacing -->
                                                <ColumnDefinition Width="75"/> <!-- Quality -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Status -->
                                            <TextBlock x:Name="YouTubeStatusText" Grid.Column="0" Text="Не проверено"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                            <!-- Latency Badge -->
                                            <Border x:Name="YouTubeLatencyBadge" Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                    BorderThickness="1" BorderBrush="{DynamicResource BorderSoftBrush}"
                                                    Background="{DynamicResource BorderSoftBrush}"
                                                    Visibility="Collapsed" Height="22" VerticalAlignment="Center">
                                                <TextBlock x:Name="YouTubeLatencyText" Text="-- мс"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Quality Badge -->
                                            <Border x:Name="YouTubeQualityBadge" Grid.Column="4" CornerRadius="4" Padding="6,2"
                                                    BorderThickness="1" BorderBrush="{DynamicResource BorderSoftBrush}"
                                                    Background="{DynamicResource BorderSoftBrush}"
                                                    Visibility="Collapsed" Height="22" VerticalAlignment="Center">
                                                <TextBlock x:Name="YouTubeQualityText" Text="Норма"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <!-- Chart Area -->
                                    <Border Grid.Row="1" x:Name="YouTubeGraphArea" Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                                            SizeChanged="YouTubeGraphArea_SizeChanged" ClipToBounds="True">
                                        <Grid>
                                            <Canvas x:Name="YouTubeGraphContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock x:Name="YouTubeGraphPlaceholderText" Text="Ожидание сбора метрик..."
                                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border x:Name="YouTubeGraphPausedState" Background="{DynamicResource SurfaceBrush}" Panel.ZIndex="10" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Идёт автоподбор" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Графики временно приостановлены" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Discord Chart Card -->
                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="18,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header Row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Service Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Metrics Group Grid -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Width="28" Height="28" CornerRadius="6"
                                                Background="{DynamicResource BorderSoftBrush}"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource IconDiscord}" Fill="#5865F2" Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>

                                        <!-- Service Name -->
                                        <TextBlock Grid.Column="1" Text="Discord"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Rigid Metrics Group -->
                                        <Grid Grid.Column="2" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/> <!-- Status -->
                                                <ColumnDefinition Width="10"/> <!-- Spacing -->
                                                <ColumnDefinition Width="65"/> <!-- Latency -->
                                                <ColumnDefinition Width="10"/> <!-- Spacing -->
                                                <ColumnDefinition Width="75"/> <!-- Quality -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Status -->
                                            <TextBlock x:Name="DiscordStatusText" Grid.Column="0" Text="Не проверено"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                            <!-- Latency Badge -->
                                            <Border x:Name="DiscordLatencyBadge" Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                    BorderThickness="1" BorderBrush="{DynamicResource BorderSoftBrush}"
                                                    Background="{DynamicResource BorderSoftBrush}"
                                                    Visibility="Collapsed" Height="22" VerticalAlignment="Center">
                                                <TextBlock x:Name="DiscordLatencyText" Text="-- мс"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Quality Badge -->
                                            <Border x:Name="DiscordQualityBadge" Grid.Column="4" CornerRadius="4" Padding="6,2"
                                                    BorderThickness="1" BorderBrush="{DynamicResource BorderSoftBrush}"
                                                    Background="{DynamicResource BorderSoftBrush}"
                                                    Visibility="Collapsed" Height="22" VerticalAlignment="Center">
                                                <TextBlock x:Name="DiscordQualityText" Text="Норма"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <!-- Chart Area -->
                                    <Border Grid.Row="1" x:Name="DiscordGraphArea" Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                                            SizeChanged="DiscordGraphArea_SizeChanged" ClipToBounds="True">
                                        <Grid>
                                            <Canvas x:Name="DiscordGraphContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock x:Name="DiscordGraphPlaceholderText" Text="Ожидание сбора метрик..."
                                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border x:Name="DiscordGraphPausedState" Background="{DynamicResource SurfaceBrush}" Panel.ZIndex="10" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Идёт автоподбор" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Графики временно приостановлены" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>


                        </Grid>

                        <Grid x:Name="DiagOverviewTabContent" Visibility="Collapsed">
                            <!-- Hidden elements to preserve C# references without modifying MainWindow.xaml.cs -->
                            <StackPanel Visibility="Collapsed">
                                <TextBlock x:Name="DiagDescText"/>
                                <Border x:Name="DiagResultBadge"/>
                                <TextBlock x:Name="DiagTitleText"/>
                                <TextBlock x:Name="LastCheckText"/>
                            </StackPanel>

                            <!-- 2-Column Dashboard: Left = Metrics (2*), Right = Guide (1*) -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column: System Context + Network Metrics stacked vertically -->
                                <Grid x:Name="DiagnosticsOverviewLeftStack" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top Card: System Context -->
                                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="16,14">
                                        <StackPanel>
                                            <TextBlock Text="КОНТЕКСТ СИСТЕМЫ"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,12"/>
                                            <UniformGrid Columns="2" Rows="2" Margin="-4">
                                                <!-- Box 1: Bypass Status -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconLightning}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Обход блокировок" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagServiceStatusText" Text="Неизвестно" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 2: VPN State -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconShield}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Состояние VPN" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagVpnStatusText" Text="Неизвестно" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 3: Active Profile -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconTune}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Активный профиль" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagProfileText" Text="Не выбран" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 4: Zapret Version -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconBox}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Версия zapret" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagVersionText" Text="Не установлен" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>

                                            <!-- Scenario Cards Container -->
                                            <UniformGrid x:Name="DiagScenarioCardsContainer" Columns="2" Rows="1" Margin="-4,0,-4,-4" Visibility="Collapsed">
                                                <!-- Tile 1: Scenario -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconProfiles}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Game Filter" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagScenarioNameText" Text="Выключен" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Tile 2: Settings/Scope -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconSettings}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock x:Name="DiagScenarioDetailLabel" Text="Охват" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagScenarioDetailText" Text="Обычный охват" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Bottom Card: Network Metrics -->
                                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,6,0,0" Padding="16,14">
                                        <StackPanel>
                                            <TextBlock Text="СЕТЕВЫЕ МЕТРИКИ"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,12"/>
                                            <UniformGrid Columns="2" Rows="2" Margin="-4">
                                                <!-- Box 1: Avg Response Time -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconRadar}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Средний отклик" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagPingText" Text="Скоро" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 2: Successful checks -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconGlobe}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Успешные запросы" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagDnsText" Text="Скоро" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 3: Failed requests -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconWarning}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Неудачные запросы" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagLossText" Text="Скоро" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Box 4: Stability -->
                                                <Border Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource IconTarget2}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Доступность" FontSize="9.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock x:Name="DiagStabilityText" Text="Нет данных" FontSize="12.5" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" TextWrapping="Wrap" TextTrimming="None"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Right Card: Troubleshooting & Guide -->
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,0" Padding="16,14" VerticalAlignment="Top" MaxHeight="{Binding ActualHeight, ElementName=DiagnosticsOverviewLeftStack}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="ПОМОЩЬ И РУКОВОДСТВО"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,0,14"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="0,0,12,0">

                                                <!-- HTTPS Latency Help -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource IconRadar}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                </Viewbox>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="HTTPS-отклик" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Показывает, как быстро сервис отвечает через HTTPS. Чем меньше значение, тем быстрее открываются страницы и медиа. Норма — до 150 мс. Если значение заметно выше, профиль может работать медленно."
                                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </StackPanel>
                                            </Grid>

                                            <Separator Background="{DynamicResource BorderBrush}" Opacity="0.4" Margin="0,0,0,10"/>

                                            <!-- Bypass Help -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource IconLightning}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                </Viewbox>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Обход блокировок" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Показывает, включён ли обход и применён ли профиль. Если сайты не открываются, вернитесь на Главную, перезапустите обход и повторите проверку."
                                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </StackPanel>
                                            </Grid>

                                            <Separator Background="{DynamicResource BorderBrush}" Opacity="0.4" Margin="0,0,0,10"/>

                                            <!-- VPN Conflict Help -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource IconShield}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                </Viewbox>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Конфликты с VPN" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="VPN может менять маршрут трафика и мешать правилам обхода. Для точной проверки временно отключите VPN, затем обновите диагностику."
                                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </StackPanel>
                                            </Grid>

                                            <Separator Background="{DynamicResource BorderBrush}" Opacity="0.4" Margin="0,0,0,10"/>

                                            <!-- DNS Help -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource IconGlobe}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                </Viewbox>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Ошибки DNS и сбои" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="DNS отвечает за поиск адресов сайтов. Если DNS работает нестабильно, сервисы могут не открываться даже при включённом обходе. Попробуйте другой профиль или перезапустите обход."
                                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </StackPanel>
                                            </Grid>

                                            <Separator Background="{DynamicResource BorderBrush}" Opacity="0.4" Margin="0,0,0,10"/>

                                            <!-- Availability Help -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource IconTarget2}" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform"/>
                                                </Viewbox>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Доступность" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Показывает итог по проверенным сервисам. Отлично — всё отвечает. Частично — часть проверок не прошла. Не подходит — лучше выбрать другой профиль."
                                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═════ TAB 3: ЖУРНАЛ ═════ -->
                        <Grid x:Name="DiagLogTabContent" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Summary Row -->
                                <RowDefinition Height="*"/>    <!-- Log Box Card -->
                            </Grid.RowDefinitions>

                            <!-- Summary Card -->
                            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Margin="0,0,24,0">
                                                <TextBlock Text="Последняя запись" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock x:Name="LogLastUpdateText" Text="--:--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,24,0">
                                                <TextBlock Text="Источник" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock x:Name="LogFileNameText" Text="в приложении" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,24,0">
                                                <TextBlock Text="Строк" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock x:Name="LogEntryCountText" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Ошибок" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock x:Name="LogErrorCountText" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button x:Name="CopyReportButton"
                                                Style="{DynamicResource PrimaryButtonStyle}" Height="28" Padding="10,0"
                                                Click="CopyReportButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Path Data="{StaticResource IconLog}" Fill="White" Stretch="Uniform"/>
                                                </Viewbox>
                                                <TextBlock Text="Скопировать отчёт" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Log Box Card -->
                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,14" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="ПОСЛЕДНИЕ СОБЫТИЯ" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12">
                                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="LogItems" Margin="0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="65"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Time}" Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontSize="11" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="13" TextWrapping="Wrap" LineHeight="19">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Severity}" Value="SUCCESS">
                                                                                <Setter Property="Foreground" Value="{DynamicResource StatusOnBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Severity}" Value="WARN">
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Severity}" Value="ERROR">
                                                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Row 1: Bottom Area (Refresh Indicator & Button) -->
                    <Grid Grid.Row="1" Margin="0,16,0,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Refresh Indicator Label (Left) -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                            <Border Width="16" Height="16" Background="{DynamicResource BorderBrush}" CornerRadius="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="DiagAutoRefreshText" 
                                       Text="Автоматическое обновление графиков — каждые 15 секунд" 
                                       VerticalAlignment="Center" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Refresh Button (Right) -->
                        <Button x:Name="CheckConnectionButton" Grid.Column="1" Click="QuickCheckButton_Click" Height="32" Width="120" Padding="14,0" Style="{DynamicResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform>
                                        <RotateTransform x:Name="RefreshIconRotation" Angle="0"/>
                                    </Viewbox.RenderTransform>
                                    <Path Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock x:Name="CheckConnectionButtonText" Text="Обновить" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Hidden technical controls for code-behind compatibility -->
                    <StackPanel Visibility="Collapsed">
                        <Border x:Name="DiagResultAccent"/>
                    </StackPanel>
                </Grid>

                <!-- Dummy PageLog Grid for compile/field generation safety -->
                <Grid x:Name="PageLog" Visibility="Collapsed"/>

            </Grid>
        </Grid>

        <!-- ══════════════════════ FOOTER ══════════════════════ -->
        <Border Grid.Row="2" x:Name="FooterStatusBar" Background="{DynamicResource FooterBrush}" Padding="20,0">
            <Border.Resources>
                <Storyboard x:Key="FooterHighlightAnimation">
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FooterHighlightLayer" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseIn"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </Border.Resources>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="-1" Opacity="0.05" Color="{DynamicResource ShadowColor}"/>
            </Border.Effect>
            <Grid>
                <Rectangle x:Name="FooterHighlightLayer" Fill="{DynamicResource FooterHighlightBrush}" Opacity="0" Margin="-20,0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="FooterWarningText"
                               Text="zapret установлен и готов к работе"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox x:Name="AdminIcon" Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource TextSecondaryBrush}" Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.1,7 14,7.9 14,9C14,10.1 13.1,11 12,11C10.9,11 10,10.1 10,9C10,7.9 10.9,7 12,7M12,13C13.33,13 16,13.67 16,15V16H8V15C8,13.67 10.67,13 12,13Z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="AdminStatusText"
                                   Text="Без прав администратора"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════ OVERLAY ══════════════════════ -->
        <Grid x:Name="MainOverlay" Grid.RowSpan="3" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="{DynamicResource OverlayBackgroundBrush}" />
            <Border x:Name="OverlayCard" Style="{DynamicResource CardStyle}"
                    Width="440" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="28" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="{DynamicResource ShadowColor}"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header (Title, Close, Body) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Mode Container (Wizard selection) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Comparison Top (Metadata + Table Header) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Comparison Body (ScrollViewer) -->
                        <RowDefinition Height="*"/>
                        <!-- Footer Buttons -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" x:Name="OverlayCloseButton" Content="✕"
                            Style="{DynamicResource HeaderActionButtonStyle}"
                            Width="32" Height="32" Padding="0"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-18,-18,0"
                            Click="OverlaySecondaryButton_Click" ToolTip="Закрыть"
                            Panel.ZIndex="10"/>

                    <StackPanel Grid.Row="0" Margin="0,0,0,0">
                        <TextBlock x:Name="OverlayTitle" Text="Заголовок" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock x:Name="OverlayBody" Text="Текст описания подтверждения или выбора."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap"
                                   LineHeight="20" Margin="0,0,0,28"/>
                    </StackPanel>

                    <!-- Specialized Mode Selection -->
                    <StackPanel Grid.Row="1" x:Name="OverlayModeContainer" Visibility="Collapsed" Margin="0,0,0,20">
                        <Button x:Name="OverlayFastModeButton" Style="{StaticResource ModeOptionButtonStyle}" Click="OverlayPrimaryButton_Click">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Быстрый" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Подходит большинству пользователей" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource PrimaryBrush}" CornerRadius="10" Padding="10,4">
                                    <TextBlock Text="≈ 1–3 мин" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>
                        <Button x:Name="OverlayAccurateModeButton" Style="{StaticResource ModeOptionButtonStyle}" Click="OverlayTertiaryButton_Click">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Точный" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Проверяет больше вариантов" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource BorderSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10,4">
                                    <TextBlock Text="≈ 5–10 мин" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Comparison top (Metadata + Table Header) -->
                    <StackPanel Grid.Row="2" x:Name="OverlayComparisonHeaderContainer" Visibility="Collapsed" Margin="0,0,0,4"/>

                    <!-- Comparison Body (ScrollViewer) -->
                    <ScrollViewer Grid.Row="3" x:Name="OverlayComparisonScroll" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,-8,20" Padding="0,0,8,0"
                                  FocusVisualStyle="{x:Null}">
                        <StackPanel x:Name="OverlayComparisonContainer"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" x:Name="OverlayStandardButtons">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1" x:Name="OverlaySecondaryButton" Content="Отмена"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="42" Margin="8,0,0,0"
                                    Click="OverlaySecondaryButton_Click"/>
                            <Button Grid.Column="0" x:Name="OverlayPrimaryButton" Content="Продолжить"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="42" Margin="0,0,8,0"
                                    Click="OverlayPrimaryButton_Click"/>
                        </Grid>

                        <Button x:Name="OverlayTertiaryButton" Content="Дополнительно"
                                Style="{DynamicResource SecondaryButtonStyle}" Height="38" Margin="0,12,0,0"
                                Visibility="Collapsed"
                                Click="OverlayTertiaryButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
