                        <!-- Row 2, Col 0: ПОВЕДЕНИЕ -->
                        <Border Grid.Row="2" Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="16,12" Margin="0,0,0,18" VerticalAlignment="Stretch">
