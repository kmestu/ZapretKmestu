                                               TextWrapping="Wrap" Margin="4,8,0,0" Visibility="Collapsed"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{DynamicResource BorderBrush}" Width="1" Margin="16,0" Opacity="0.5"/>

                                <Button Grid.Column="2" x:Name="RefreshProfilesButton"
