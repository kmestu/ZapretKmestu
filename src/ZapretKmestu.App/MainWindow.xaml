                                          Checked="ShowVpnWarningCheckbox_Changed"
                                          Unchecked="ShowVpnWarningCheckbox_Changed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Предупреждение о VPN" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="16" Height="16" Background="{DynamicResource BorderBrush}" CornerRadius="8"
                                                Margin="8,0,0,0" Cursor="Help" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0" ToolTipService.ShowDuration="20000" VerticalAlignment="Center">
                                            <Border.ToolTip>
                                                <ToolTip Style="{x:Null}" Background="Transparent" BorderThickness="0" Padding="0">
                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
